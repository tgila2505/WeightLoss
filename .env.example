# Root environment template for local development.
# Copy needed values into a local `.env` file per service or export them in your shell.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_ENV=development
BACKEND_JWT_SECRET=replace-with-a-secure-secret
BACKEND_JWT_ALGORITHM=HS256
BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI services
AI_SERVICES_HOST=127.0.0.1
AI_SERVICES_PORT=8001
AI_SERVICES_ENV=development

# Shared infrastructure references
POSTGRES_URL=postgresql+psycopg://user:password@localhost:5432/app
REDIS_URL=redis://localhost:6379/0
VECTOR_DB_URL=http://localhost:6333

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000

# Admin
ADMIN_EMAIL=tanzeel_anwar@hotmail.com

# AI provider placeholders
GROQ_API_KEY=your-groq-key
MISTRAL_API_KEY=your-mistral-key
